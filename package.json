{
  "name": "bitcoin-decoder",
  "version": "0.1.0",
  "description": "Decode bitcoin QR codes, URIs, and raw strings",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "author": {
    "name": "psycarlo",
    "email": "psycarlo1@gmail.com",
    "url": "https://psycarlo.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "bip-321": "^0.0.10",
    "light-bolt11-decoder": "^3.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3",
    "ultracite": "7.2.3"
  },
  "keywords": [
    "bitcoin",
    "decode",
    "on-chain",
    "lightning",
    "ark",
    "bip-21",
    "bip-321",
    "uri"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Psycarlo/bitcoin-decode"
  },
  "bugs": {
    "email": "psycarlo1@gmail.com",
    "url": "https://github.com/Psycarlo/bitcoin-decode/issues"
  },
  "homepage": "https://github.com/Psycarlo/bitcoin-decode#readme",
  "workspaces": [
    "website"
  ]
}
